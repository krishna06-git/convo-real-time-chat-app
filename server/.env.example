# ============================================
#  Convo Server — Environment Variables
#  Copy this to .env and fill in your values
# ============================================

# MongoDB Atlas connection string
# Get this from: https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/convo?retryWrites=true&w=majority

# JWT Secret — use a long random string (64+ chars)
# Generate one at: https://www.uuidgenerator.net/
JWT_SECRET=replace-this-with-a-very-long-random-secret-string-at-least-64-characters

# Cloudinary credentials
# Get these from: https://cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# The URL where your frontend is served (for CORS)
# In production on Render, this will be your Render app URL
# e.g., https://convo-app.onrender.com
# Leave empty if frontend is served from the same server (recommended)
CLIENT_URL=

# Server port (Render sets this automatically)
PORT=5001

# Node environment
NODE_ENV=production
